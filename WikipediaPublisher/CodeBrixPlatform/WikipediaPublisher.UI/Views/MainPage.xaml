<Page x:Class="WikipediaPublisher.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:WikipediaPublisher.Views"
      xmlns:vm="using:WikipediaPublisher.ViewModels"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
      FontFamily="{StaticResource OpenSansFont}">

    <Page.DataContext>
        <vm:MainViewModel />
    </Page.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Search Wikipedia:"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBox Grid.Column="1" Height="36"
                     VerticalAlignment="Center" VerticalContentAlignment="Center"
                     PlaceholderText="e.g. cuneiform writing"
                     KeyDown="SearchBox_KeyDown"
                     Text="{Binding SearchTerms, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="2" Width="110" Height="36" Margin="12,0,0,0"
                    Content="Search"
                    Command="{Binding SearchCommand}" />
        </Grid>

        <!-- Center: embedded browser. Every Skia head now has a WebView2 - the Windows,
             Skia-on-WPF and macOS runtimes have it built in, and the Linux heads get it
             from the CodeBrix.Platform.WebView.ApacheLicenseForever add-in (WPE WebKit). -->
        <WebView2 Grid.Row="1" x:Name="Browser" />

        <!-- Status line -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Height="8" VerticalAlignment="Center"
                         Minimum="0" Maximum="100"
                         Value="{Binding ProgressValue}" />
            <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding StatusText}" />
        </Grid>

        <!-- Bottom bar: output file path (+ Select dialog), page size, Publish -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Save PDF to:"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBox Grid.Column="1" Height="36"
                     VerticalAlignment="Center" VerticalContentAlignment="Center"
                     PlaceholderText="Click Select… (or type a full .pdf path)"
                     Text="{Binding OutputFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="2" Height="36" Margin="8,0,0,0"
                    Content="Select…"
                    Command="{Binding SelectOutputFileCommand}" />
            <TextBlock Grid.Column="3" Text="Page size:"
                       VerticalAlignment="Center" Margin="16,0,12,0" />
            <ComboBox Grid.Column="4" Width="210" Height="36" VerticalAlignment="Center"
                      ItemsSource="{Binding PageSizeNames}"
                      SelectedItem="{Binding SelectedPageSizeName, Mode=TwoWay}" />
            <Button Grid.Column="5" Width="130" Height="40" Margin="16,0,0,0"
                    HorizontalAlignment="Right"
                    Style="{ThemeResource AccentButtonStyle}"
                    Content="Publish"
                    Command="{Binding PublishCommand}" />
        </Grid>
    </Grid>
</Page>
