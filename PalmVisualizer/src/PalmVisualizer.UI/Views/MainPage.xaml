<Page
    x:Class="PalmVisualizer.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PalmVisualizer.ViewModels"
    xmlns:camera="using:PalmVisualizer.Camera"
    xmlns:game="using:CodeBrix.Platform.GameEngine.Host.Rendering"
    xmlns:converters="using:CodeBrix.Platform.UI.Converters"
    FontFamily="{StaticResource RobotoFont}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.DataContext>
        <vm:MainViewModel />
    </Page.DataContext>

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True" />
    </Page.Resources>

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
            <TextBlock Text="Palm Visualizer" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" />
            <ComboBox MinWidth="280" VerticalAlignment="Center"
                      ItemsSource="{Binding Cameras}"
                      SelectedItem="{Binding SelectedCamera, Mode=TwoWay}"
                      IsEnabled="{Binding IsCameraMode}" />
        </StackPanel>

        <!-- The main viewer: the mirrored live preview in Camera Mode; the palm-reactive
             shader visual in Visualize Mode -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Background="Black">
            <Grid>
                <camera:CameraCanvas x:Name="PreviewCanvas"
                                     Visibility="{Binding IsCameraMode, Converter={StaticResource VisibleWhenTrue}}" />
                <game:GameSurfaceCanvas x:Name="VisualizerCanvas"
                                        Visibility="{Binding IsCameraMode, Converter={StaticResource VisibleWhenFalse}}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8"
                        Visibility="{Binding IsCameraMode, Converter={StaticResource VisibleWhenTrue}}">
                <Button Content="Visualize!" Command="{Binding VisualizeCommand}"
                        MinWidth="120" Style="{ThemeResource AccentButtonStyle}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8"
                        Visibility="{Binding IsCameraMode, Converter={StaticResource VisibleWhenFalse}}">
                <Button Content="Back" Command="{Binding BackCommand}" MinWidth="100" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding StatusText}" Margin="0,8,0,0" TextWrapping="Wrap" />
    </Grid>
</Page>
